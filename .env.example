# ── Database ─────────────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://HOST:3306/DB_NAME?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Access token signing key (Base64, min 256-bit / 32 char)
JWT_SECRET=change_me_to_a_strong_base64_encoded_secret_min_32_chars
JWT_EXPIRATION=900000

# Refresh token signing key (must be DIFFERENT from JWT_SECRET)
JWT_REFRESH_SECRET=change_me_to_a_different_strong_base64_encoded_secret
JWT_REFRESH_EXPIRATION=604800000
